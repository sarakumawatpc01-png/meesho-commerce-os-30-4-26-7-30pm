# =============================================================================
# MEESHO COMMERCE OS — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ── DATABASE ─────────────────────────────────────────────────────────────────
POSTGRES_DB=meesho_engine
POSTGRES_USER=meesho
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_POSTGRES_PASSWORD
DATABASE_URL=postgresql://meesho:REPLACE_WITH_SECURE_POSTGRES_PASSWORD@postgres:5432/meesho_engine

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_SECURE_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_WITH_SECURE_REDIS_PASSWORD@redis:6379

# ── ENGINE ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
ENGINE_SECRET=REPLACE_WITH_64_CHAR_JWT_SECRET
# Default superadmin seeded in DB: admin@agencyfic.com / Admin@123
# Change via Admin → Settings → Superadmin tab after install
SUPER_ADMIN_EMAIL=admin@agencyfic.com
SUPER_ADMIN_PASSWORD=Admin@123

# ── OPENROUTER (AI) ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE
# Model assignments (can be changed in Admin → Settings → AI Models)
AI_MODEL_SEO=google/gemini-flash-1.5
AI_MODEL_PRODUCT=anthropic/claude-3.5-sonnet
AI_MODEL_BLOG=mistralai/mistral-nemo
AI_MODEL_AD_COPY=openai/gpt-4o-mini
AI_MODEL_ASSISTANT=google/gemini-2.0-flash
AI_MODEL_HINDI=google/gemini-flash-1.5

# ── WHATSAPP BUSINESS API ─────────────────────────────────────────────────────
# Get from: Meta Business → WhatsApp → API Setup
WABA_TOKEN=YOUR_WHATSAPP_PERMANENT_ACCESS_TOKEN
WABA_PHONE_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID
WHATSAPP_VERIFY_TOKEN=YOUR_WHATSAPP_WEBHOOK_VERIFY_TOKEN
WHATSAPP_NUMBER=91XXXXXXXXXX

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
EMAIL_FROM=noreply@yourdomain.com

# ── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET

# ── CLOUDFLARE R2 (Image CDN) ─────────────────────────────────────────────────
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY
R2_BUCKET_NAME=meesho-products
R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# ── SENTRY (Error Tracking) ───────────────────────────────────────────────────
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID

# ── DATASEO (SEO Audit API) ───────────────────────────────────────────────────
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# ── ENCRYPTION ────────────────────────────────────────────────────────────────
# AES-256 key for encrypting API keys stored in DB (must be 32 bytes)
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_ENCRYPTION_KEY

# ── SUPER ADMIN PANEL DOMAIN ──────────────────────────────────────────────────
SUPERADMIN_DOMAIN=meesho.agencyfic.com
NEXT_PUBLIC_SUPERADMIN_DOMAIN=meesho.agencyfic.com

# ── SMTP (for Email OTP — optional but needed if email_otp_enabled=true) ───────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ── MEESHO ACCOUNTS (for order fulfillment rotation) ─────────────────────────
# Up to 4 accounts - set in Admin → Settings → Fulfillment → Meesho Accounts
# These are encrypted in DB; this is for initial seed only
MEESHO_ACCOUNT_1_PHONE=
MEESHO_ACCOUNT_1_PASSWORD=

# ── MISC ──────────────────────────────────────────────────────────────────────
LOG_DIR=./logs
SITES_DIR=./sites
LOG_LEVEL=info
TZ=Asia/Kolkata
CORS_ORIGINS=http://localhost:3000
